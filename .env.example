# Base URL of the Go BFF (evm-oracle-demo-api). Required.
NEXT_PUBLIC_API_URL=http://localhost:8080

# Browser-reachable WebSocket base for /ws/stream. Optional.
# When unset it is derived from NEXT_PUBLIC_API_URL (http->ws, https->wss).
# NEXT_PUBLIC_WS_URL=ws://localhost:8080

# Target chain. Defaults to Ethereum Sepolia.
NEXT_PUBLIC_CHAIN_ID=11155111
NEXT_PUBLIC_CHAIN_NAME=Ethereum Sepolia
NEXT_PUBLIC_EXPLORER_URL=https://sepolia.etherscan.io

# Upwork profile URL. Footer/about Upwork link only renders when this is set (OQ-09).
# NEXT_PUBLIC_UPWORK_URL=https://www.upwork.com/freelancers/your-id

# Public JSON-RPC endpoint for read-only on-chain calls (server-side only).
# Defaults to a public Sepolia node; override with your own/keyed endpoint.
RPC_URL=https://ethereum-sepolia-rpc.publicnode.com
